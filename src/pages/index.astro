---
import { client } from '../lib/sanity.js'

const mapboxToken = import.meta.env.PUBLIC_MAPBOX_TOKEN

const turer = await client.fetch(`*[_type == "tur"] | order(datum desc) {
  _id,
  toppnamn,
  datum,
  hojd,
  lat,
  lng
}`)

const senaste = turer.slice(0, 5)
const medKoord = turer.filter((t: any) => t.lat && t.lng)
---

<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Splitboardcupen</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Albert+Sans:wght@400;500;700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <link href="https://api.mapbox.com/mapbox-gl-js/v3.3.0/mapbox-gl.css" rel="stylesheet" />
  <style is:global>
    .mapboxgl-ctrl-logo,
    .mapboxgl-ctrl-attrib,
    .mapboxgl-ctrl-bottom-left,
    .mapboxgl-ctrl-bottom-right { display: none !important; }
  </style>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --off-white: #F2EDD7;
      --near-black: #1A2E6B;
    }

    body {
      background: var(--off-white);
      color: var(--near-black);
      font-family: 'Albert Sans', sans-serif;
      min-height: 100vh;
      overflow-x: hidden;
    }

    header {
      border-bottom: 1px solid var(--near-black);
      padding: clamp(1rem, 4vw, 2rem);
      display: flex;
      align-items: baseline;
      gap: 1rem;
    }

    header a.site-title {
      font-size: 1.25rem;
      font-weight: 700;
      letter-spacing: -0.02em;
      text-decoration: none;
      color: inherit;
    }

    header nav {
      display: flex;
      gap: 1rem;
      align-items: baseline;
    }

    header nav a {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.75rem;
      text-decoration: none;
      color: inherit;
      opacity: 0.5;
    }

    header nav a:hover { opacity: 1; }

    main {
      max-width: 900px;
      margin: 0 auto;
      padding: clamp(16px, 4vw, 48px);
    }

    #map {
      width: 100%;
      height: 480px;
      margin-bottom: 3rem;
    }

    @media (max-width: 600px) {
      #map { height: 300px; }
    }

    .tur-rad {
      display: grid;
      grid-template-columns: 1fr 110px 80px;
      gap: 0.75rem;
      align-items: center;
      padding: 1.25rem 0;
      border-bottom: 1px solid rgba(26,46,107,0.12);
      text-decoration: none;
      color: inherit;
      transition: background 0.15s;
    }

    @media (max-width: 480px) {
      .tur-rad { grid-template-columns: 1fr 90px; }
      .tur-hojd { display: none; }
    }

    .tur-rad:hover {
      background: var(--near-black);
      color: var(--off-white);
      padding-left: 0.75rem;
      padding-right: 0.75rem;
      margin-left: -0.75rem;
      margin-right: -0.75rem;
    }

    .tur-namn {
      font-size: 1.05rem;
      font-weight: 500;
      letter-spacing: -0.01em;
      min-width: 0;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .tur-meta {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.78rem;
    }

    .se-alla {
      display: inline-block;
      margin-top: 2rem;
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.72rem;
      letter-spacing: 0.03em;
      color: var(--near-black);
      text-decoration: none;
      opacity: 0.4;
    }

    .se-alla:hover { opacity: 0.85; }
  </style>
</head>
<body>
  <header>
    <a href="/" class="site-title">Splitboardcupen</a>
    <nav>
      <a href="/logg">Säsongslogg</a>
      <a href="/protokoll">Protokoll</a>
    </nav>
  </header>

  <main>
    <div id="map"></div>

    {senaste.map((tur: any) => (
      <a href={`/tur/${tur._id}`} class="tur-rad">
        <span class="tur-namn">{tur.toppnamn}</span>
        <span class="tur-meta">{new Date(tur.datum).toLocaleDateString('sv-SE')}</span>
        <span class="tur-meta tur-hojd">{tur.hojd} m</span>
      </a>
    ))}

    <a href="/logg" class="se-alla">Fullständigt register →</a>
  </main>

  <script is:inline src="https://api.mapbox.com/mapbox-gl-js/v3.3.0/mapbox-gl.js"></script>

  <script define:vars={{ medKoord, mapboxToken }}>
    mapboxgl.accessToken = mapboxToken

    const bounds = medKoord.reduce(
      (b, t) => b.extend([t.lng, t.lat]),
      new mapboxgl.LngLatBounds([medKoord[0].lng, medKoord[0].lat], [medKoord[0].lng, medKoord[0].lat])
    )

    const map = new mapboxgl.Map({
      container: 'map',
      style: {
        version: 8,
        glyphs: 'mapbox://fonts/mapbox/{fontstack}/{range}',
        sources: {
          dem: {
            type: 'raster-dem',
            url: 'mapbox://mapbox.mapbox-terrain-dem-v1',
            tileSize: 512
          },
          terrain: {
            type: 'vector',
            url: 'mapbox://mapbox.mapbox-terrain-v2'
          }
        },
        layers: [
          {
            id: 'background',
            type: 'background',
            paint: { 'background-color': '#F2EDD7' }
          },
          {
            id: 'hillshade',
            type: 'hillshade',
            source: 'dem',
            paint: {
              'hillshade-shadow-color': '#1A2E6B',
              'hillshade-highlight-color': '#F2EDD7',
              'hillshade-accent-color': '#3a4e8b',
              'hillshade-exaggeration': 0.6
            }
          },
          {
            id: 'contours-minor',
            type: 'line',
            source: 'terrain',
            'source-layer': 'contour',
            filter: ['==', ['get', 'index'], -1],
            paint: {
              'line-color': '#1A2E6B',
              'line-opacity': 0.15,
              'line-width': 0.5
            }
          },
          {
            id: 'contours-major',
            type: 'line',
            source: 'terrain',
            'source-layer': 'contour',
            filter: ['>', ['get', 'index'], 0],
            paint: {
              'line-color': '#1A2E6B',
              'line-opacity': 0.45,
              'line-width': 1.1
            }
          }
        ]
      },
      bounds,
      fitBoundsOptions: { padding: 64, maxZoom: 12 },
      interactive: true
    })

    medKoord.forEach(tur => {
      const el = document.createElement('div')
      el.style.cssText = [
        'width:8px',
        'height:8px',
        'background:#1A2E6B',
        'border-radius:50%',
        'cursor:pointer'
      ].join(';')
      el.addEventListener('click', () => { window.location.href = `/tur/${tur._id}` })

      new mapboxgl.Marker({ element: el })
        .setLngLat([tur.lng, tur.lat])
        .addTo(map)
    })
  </script>
</body>
</html>
