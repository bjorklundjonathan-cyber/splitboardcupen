---
import { client } from '../lib/sanity.js'

const turer = await client.fetch(`*[_type == "tur"] | order(datum desc) {
  _id,
  toppnamn,
  datum,
  hojd,
  stigtid,
  snodjup,
  vindstyrka,
  vindriktning,
  temperatur,
  beskrivning
}`)
---

<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Säsongslogg – Splitboardcupen</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Albert+Sans:wght@400;500;700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --off-white: #F2EDD7;
      --near-black: #1A2E6B;
    }

    body {
      background: var(--off-white);
      color: var(--near-black);
      font-family: 'Albert Sans', sans-serif;
      min-height: 100vh;
      overflow-x: hidden;
    }

    header {
      border-bottom: 1px solid var(--near-black);
      padding: clamp(1rem, 4vw, 2rem);
      display: flex;
      align-items: baseline;
      gap: 1rem;
    }

    header a.site-title {
      font-size: 1.25rem;
      font-weight: 700;
      letter-spacing: -0.02em;
      text-decoration: none;
      color: inherit;
    }

    header a.site-title:hover { text-decoration: underline; }

    header nav {
      display: flex;
      gap: 1rem;
      align-items: baseline;
      flex-wrap: wrap;
    }

    @media (max-width: 600px) {
      header { flex-direction: column; gap: 0.5rem; }
    }

    header nav a {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.75rem;
      text-decoration: none;
      color: inherit;
      opacity: 0.5;
    }

    header nav a:hover { opacity: 1; }
    header nav a.active { opacity: 1; }

    main {
      padding: clamp(16px, 4vw, 48px);
      max-width: 1200px;
      margin: 0 auto;
    }

    .grid-header,
    .tur-rad {
      display: grid;
      grid-template-columns: 1fr 110px 80px 90px 90px;
      gap: 0.75rem;
      align-items: center;
    }

    @media (max-width: 600px) {
      .grid-header,
      .tur-rad {
        grid-template-columns: 1fr 100px 70px;
      }
      .col-stigtid,
      .col-snodjup { display: none; }
    }

    .grid-header {
      padding: 0.75rem 0;
      border-bottom: 1px solid var(--near-black);
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.65rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      opacity: 0.5;
    }

    .tur-rad {
      padding: 1.25rem 0;
      border-bottom: 1px solid rgba(26,46,107,0.12);
      text-decoration: none;
      color: inherit;
      transition: background 0.15s;
    }

    .tur-rad:hover {
      background: var(--near-black);
      color: var(--off-white);
      padding-left: 0.75rem;
      padding-right: 0.75rem;
      margin-left: -0.75rem;
      margin-right: -0.75rem;
    }

    .tur-namn {
      font-size: 1.05rem;
      font-weight: 500;
      letter-spacing: -0.01em;
      min-width: 0;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .tur-meta {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.78rem;
    }

    .empty {
      padding: 4rem 0;
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.85rem;
      opacity: 0.4;
    }

    .season-tag {
      display: inline-block;
      background: var(--near-black);
      color: var(--off-white);
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.65rem;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      padding: 0.2rem 0.5rem;
      margin-bottom: 2rem;
      margin-top: 1.5rem;
    }
  </style>
</head>
<body>
  <header>
    <a href="/" class="site-title">Splitboardcupen</a>
    <nav>
      <a href="/logg" class="active">Säsongslogg</a>
      <a href="/protokoll">Protokoll</a>
      <a href="/registrera">Registrera</a>
    </nav>
  </header>

  <main>
    <div class="season-tag">Säsong 2024/25</div>

    {turer.length === 0 ? (
      <p class="empty">Inga turer registrerade ännu.</p>
    ) : (
      <>
        <div class="grid-header">
          <span>Topp</span>
          <span>Datum</span>
          <span>Höjd</span>
          <span class="col-stigtid">Stigtid</span>
          <span class="col-snodjup">Snödjup</span>
        </div>
        {turer.map((tur) => (
          <a href={`/tur/${tur._id}`} class="tur-rad">
            <span class="tur-namn">{tur.toppnamn}</span>
            <span class="tur-meta">{new Date(tur.datum).toLocaleDateString('sv-SE')}</span>
            <span class="tur-meta">{tur.hojd} m</span>
            <span class="tur-meta col-stigtid">{tur.stigtid} min</span>
            <span class="tur-meta col-snodjup">{tur.snodjup} cm</span>
          </a>
        ))}
      </>
    )}
  </main>
</body>
</html>
