---
export const prerender = false

import { client } from '../../lib/sanity.js'

const { id } = Astro.params

const tur = await client.fetch(`*[_type == "tur" && _id == $id][0] {
  toppnamn,
  datum,
  hojd,
  stigtid,
  snodjup,
  vindstyrka,
  vindriktning,
  temperatur,
  beskrivning,
  lat,
  lng,
  "foton": foton[].asset->url
}`, { id })

if (!tur) return Astro.redirect('/')

const mapboxToken = import.meta.env.PUBLIC_MAPBOX_TOKEN
const hasMap = tur.lat && tur.lng
---

<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{tur.toppnamn} – Splitboardcupen</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Albert+Sans:wght@400;500;700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />
  {hasMap && <link href="https://api.mapbox.com/mapbox-gl-js/v3.3.0/mapbox-gl.css" rel="stylesheet" />}
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --off-white: #fdfbf4;
      --near-black: #161616;
      --lime: #eafe53;
    }

    body {
      background: var(--off-white);
      color: var(--near-black);
      font-family: 'Albert Sans', sans-serif;
      min-height: 100vh;
      overflow-x: hidden;
    }

    header {
      border-bottom: 1px solid var(--near-black);
      padding: clamp(1rem, 4vw, 2rem);
      display: flex;
      align-items: baseline;
      gap: 1rem;
    }

    header a.site-title {
      font-size: 1.25rem;
      font-weight: 700;
      letter-spacing: -0.02em;
      text-decoration: none;
      color: inherit;
    }

    header a.site-title:hover { text-decoration: underline; }

    header nav {
      display: flex;
      gap: 1rem;
      align-items: baseline;
    }

    header nav a {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.75rem;
      text-decoration: none;
      color: inherit;
      opacity: 0.5;
    }

    header nav a:hover { opacity: 1; }

    main {
      max-width: 900px;
      margin: 0 auto;
      padding: clamp(16px, 4vw, 48px);
    }

    .tilbaka {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.75rem;
      letter-spacing: 0.04em;
      text-decoration: none;
      color: var(--near-black);
      opacity: 0.5;
      display: inline-block;
      margin-bottom: 2rem;
    }

    .tilbaka:hover { opacity: 1; }

    h1 {
      font-size: clamp(1.75rem, 5vw, 3.5rem);
      font-weight: 700;
      letter-spacing: -0.03em;
      line-height: 1;
      margin-bottom: 0.5rem;
    }

    .datum {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.8rem;
      opacity: 0.5;
      margin-bottom: 3rem;
    }

    .stats {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      border-top: 1px solid var(--near-black);
      border-left: 1px solid var(--near-black);
      margin-bottom: 3rem;
    }

    @media (max-width: 480px) {
      .stats {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    .stat {
      border-right: 1px solid var(--near-black);
      border-bottom: 1px solid var(--near-black);
      padding: 1rem;
    }

    .stat-label {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.6rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      opacity: 0.45;
      margin-bottom: 0.4rem;
    }

    .stat-value {
      font-family: 'IBM Plex Mono', monospace;
      font-size: clamp(1rem, 4vw, 1.4rem);
      font-weight: 500;
      letter-spacing: -0.02em;
    }

    .stat-unit {
      font-size: 0.7rem;
      opacity: 0.5;
      margin-left: 0.15rem;
    }

    .beskrivning {
      font-size: 1.05rem;
      line-height: 1.7;
      max-width: 60ch;
      margin-bottom: 3rem;
      opacity: 0.85;
    }

    #map {
      width: 100%;
      height: 380px;
      margin-bottom: 3rem;
    }

    @media (max-width: 480px) {
      #map { height: 260px; }
    }

    .mapboxgl-ctrl-logo,
    .mapboxgl-ctrl-attrib { display: none !important; }

    .foto-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
      gap: 0.5rem;
    }

    @media (max-width: 480px) {
      .foto-grid {
        grid-template-columns: 1fr;
      }
    }

    .foto-grid img {
      width: 100%;
      aspect-ratio: 4/3;
      object-fit: cover;
      display: block;
    }

    .lime-bar {
      height: 4px;
      background: var(--lime);
      margin-bottom: 3rem;
    }
  </style>
</head>
<body>
  <header>
    <a href="/" class="site-title">Splitboardcupen</a>
    <nav>
      <a href="/">Säsongslogg</a>
      <a href="/protokoll">Protokoll</a>
    </nav>
  </header>

  <main>
    <a href="/" class="tilbaka">← Alla turer</a>

    <h1>{tur.toppnamn}</h1>
    <p class="datum">{new Date(tur.datum).toLocaleDateString('sv-SE', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' })}</p>

    <div class="lime-bar"></div>

    <div class="stats">
      <div class="stat">
        <div class="stat-label">Höjd</div>
        <div class="stat-value">{tur.hojd}<span class="stat-unit">m</span></div>
      </div>
      <div class="stat">
        <div class="stat-label">Stigtid</div>
        <div class="stat-value">{tur.stigtid}<span class="stat-unit">min</span></div>
      </div>
      <div class="stat">
        <div class="stat-label">Snödjup</div>
        <div class="stat-value">{tur.snodjup}<span class="stat-unit">cm</span></div>
      </div>
      <div class="stat">
        <div class="stat-label">Vind</div>
        <div class="stat-value">{tur.vindstyrka}<span class="stat-unit">m/s</span></div>
      </div>
      <div class="stat">
        <div class="stat-label">Vindriktning</div>
        <div class="stat-value">{tur.vindriktning}</div>
      </div>
      <div class="stat">
        <div class="stat-label">Temperatur</div>
        <div class="stat-value">{tur.temperatur}<span class="stat-unit">°C</span></div>
      </div>
    </div>

    {hasMap && <div id="map"></div>}

    {tur.beskrivning && (
      <p class="beskrivning">{tur.beskrivning}</p>
    )}

    {tur.foton && tur.foton.length > 0 && (
      <div class="foto-grid">
        {tur.foton.map((url) => (
          <img src={url} alt={tur.toppnamn} loading="lazy" />
        ))}
      </div>
    )}
  </main>

  {hasMap && (
    <script
      is:inline
      src="https://api.mapbox.com/mapbox-gl-js/v3.3.0/mapbox-gl.js"
    ></script>
  )}

  {hasMap && (
    <script define:vars={{ lat: tur.lat, lng: tur.lng, mapboxToken }}>
      mapboxgl.accessToken = mapboxToken

      const map = new mapboxgl.Map({
        container: 'map',
        style: {
          version: 8,
          glyphs: 'mapbox://fonts/mapbox/{fontstack}/{range}',
          sources: {
            dem: {
              type: 'raster-dem',
              url: 'mapbox://mapbox.mapbox-terrain-dem-v1',
              tileSize: 512
            },
            terrain: {
              type: 'vector',
              url: 'mapbox://mapbox.mapbox-terrain-v2'
            }
          },
          layers: [
            {
              id: 'background',
              type: 'background',
              paint: { 'background-color': '#fdfbf4' }
            },
            {
              id: 'hillshade',
              type: 'hillshade',
              source: 'dem',
              paint: {
                'hillshade-shadow-color': '#161616',
                'hillshade-highlight-color': '#fdfbf4',
                'hillshade-accent-color': '#4a4a3a',
                'hillshade-exaggeration': 0.6
              }
            },
            {
              id: 'contours-minor',
              type: 'line',
              source: 'terrain',
              'source-layer': 'contour',
              filter: ['==', ['get', 'index'], -1],
              paint: {
                'line-color': '#161616',
                'line-opacity': 0.15,
                'line-width': 0.5
              }
            },
            {
              id: 'contours-major',
              type: 'line',
              source: 'terrain',
              'source-layer': 'contour',
              filter: ['>', ['get', 'index'], 0],
              paint: {
                'line-color': '#161616',
                'line-opacity': 0.45,
                'line-width': 1.1
              }
            }
          ]
        },
        center: [lng, lat],
        zoom: 13,
        attributionControl: true,
        interactive: true
      })

      // Lime-punkt som markör
      const el = document.createElement('div')
      el.style.cssText = [
        'width:12px',
        'height:12px',
        'background:#eafe53',
        'border-radius:50%',
        'border:2px solid #161616',
        'box-shadow:0 0 0 1.5px #eafe53'
      ].join(';')

      new mapboxgl.Marker({ element: el })
        .setLngLat([lng, lat])
        .addTo(map)
    </script>
  )}
</body>
</html>
